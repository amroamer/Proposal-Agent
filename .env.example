# Proposal Agent - Environment Template
# Copy to .env and fill in real values. Never commit the real .env.

# ---- App ----
APP_NAME=Proposal Agent
APP_BASE_PATH=/ProposalAgent
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- Database ----
POSTGRES_USER=proposal_agent
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=proposal_agent

# ---- Security ----
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=replace-with-64-byte-random-hex
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# ---- LLM ----
OLLAMA_DEFAULT_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
LLM_REQUEST_TIMEOUT_SECONDS=300

# ---- Mail (dev: MailHog; prod: SMTP relay) ----
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@proposal-agent.kpmg.local

# ---- CORS / Frontend ----
FRONTEND_ORIGIN=http://localhost

# ---- First Admin Bootstrap (used once by init-first-admin.sh) ----
FIRST_ADMIN_EMAIL=admin@kpmg.local
FIRST_ADMIN_PASSWORD=ChangeMe-StrongP@ssw0rd!
